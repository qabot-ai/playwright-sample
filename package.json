{
    "name": "Common Automation Framework",
    "version": "3.0.3",
    "description": "",
    "scripts": {
        "clean": "rimraf build-js & rimraf allure-results",
        "test:prod": "cross-env environmentToRun=prod playwright test --workers=3",
        "test:dev": "cross-env environmentToRun=dev playwright test --workers=3",
        "shard": "cross-env environmentToRun=prod npx playwright test --project=$(project) --shard=$(shard)",
        "report": "allure generate allure-results --clean",
        "open:allure:report": "allure open",
        "prettify": "prettier --config \"src/main/resources/linters/.prettierrc.js\" --ignore-path \"src/main/resources/linters/.prettierignore\" --write \"./**/*.{ts,tsx,js,jsx,json,yaml,yml,eslintrc,md}\" ",
        "lint": "eslint --config src/main/resources/linters/.eslintrc.json --ignore-path src/main/resources/linters/.eslintignore --ext .js,.ts,.tsx .",
        "lintFix": "eslint --config src/main/resources/linters/.eslintrc.json --fix src/**/*.ts",
        "record": "npx playwright codegen",
        "playwrightreport": "npx playwright show-report",
        "generateEmailReport": "npx ts-node src\\main\\resources\\allure\\emailGenerator.ts"
    },
    "keywords": [
        "Playwright",
        "Typescript"
    ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@playwright/test": "^1.59.0",
        "@reportportal/agent-js-playwright": "^5.0.8",
        "@types/fs-extra": "^9.0.13",
        "@types/jasmine": "^2.5.43",
        "@types/node": "^22.7.9",
        "cheerio": "1.0.0-rc.2",
        "cross-env": "7.0.3",
        "dotenv": "16.4.1",
        "eslint": "^8.30.0",
        "eslint-config-standard-with-typescript": "^24.0.0",
        "eslint-plugin-import": "^2.26.0",
        "eslint-plugin-n": "^15.6.0",
        "eslint-plugin-promise": "^6.1.1",
        "eslint-plugin-simple-import-sort": "^8.0.0",
        "prettier": "^2.7.1",
        "typescript": "^5.6.3"
    },
    "dependencies": {
        "@types/node": "^22.15.18",
        "allure-commandline": "^2.20.1",
        "allure-playwright": "^2.0.0-beta.20",
        "cheerio": "^1.0.0-rc.12",
        "file-exists": "^5.0.1",
        "fs-extra": "^10.1.0",
        "ts-node": "^10.9.2",
        "winston": "^3.14.2"
    }
}
